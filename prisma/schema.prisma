// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Organizations - multi-tenancy support
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  stores             Store[]
  locations          InventoryLocation[]
  products           Product[]
  suppliers          Supplier[]
  inventoryBalances  InventoryBalance[]
  stockMovements     StockMovement[]
  purchaseOrders     PurchaseOrder[]
  alerts             Alert[]
  automations        Automation[]
  auditLogs          AuditLog[]

  @@index([slug])
}

// Users
model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  password       String
  role           String   @default("staff") // admin, manager, staff
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([email])
}

// Stores
model Store {
  id             String   @id @default(cuid())
  name           String
  code           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  locations Store_InventoryLocation[]
  movements StockMovement[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Inventory Locations (store, backroom, warehouse, etc.)
model InventoryLocation {
  id             String   @id @default(cuid())
  name           String
  code           String
  type           String   // store, backroom, warehouse, receiving, virtual
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  storeLinks     Store_InventoryLocation[]
  balances       InventoryBalance[]
  movementsTo    StockMovement[] @relation("to_location")
  movementsFrom  StockMovement[] @relation("from_location")

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Junction table for Store <-> InventoryLocation
model Store_InventoryLocation {
  id                   String   @id @default(cuid())
  storeId              String
  store                Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventoryLocationId  String
  location             InventoryLocation @relation(fields: [inventoryLocationId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())

  @@unique([storeId, inventoryLocationId])
  @@index([storeId])
  @@index([inventoryLocationId])
}

// Products
model Product {
  id             String   @id @default(cuid())
  sku            String
  name           String
  barcode        String?
  category       String?
  brand          String?
  price          Decimal  @db.Decimal(10, 2)
  reorderPoint   Int      @default(5)
  reorderQty     Int      @default(10)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  balances       InventoryBalance[]
  movements      StockMovement[]
  suppliers      Supplier_Product[]
  poLineItems     PurchaseOrderLineItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([barcode])
}

// Inventory Balances
model InventoryBalance {
  id                   String   @id @default(cuid())
  quantity             Int
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId            String
  product              Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLocationId  String
  location             InventoryLocation @relation(fields: [inventoryLocationId], references: [id], onDelete: Cascade)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([organizationId, productId, inventoryLocationId])
  @@index([organizationId])
  @@index([productId])
  @@index([inventoryLocationId])
}

// Stock Movements (immutable ledger)
model StockMovement {
  id                   String   @id @default(cuid())
  type                 String   // manual_adjustment, transfer, purchase_receipt, sale, return, damage, count_correction
  quantity             Int
  notes                String?
  organizationId       String
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  productId            String
  product              Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryLocationId  String
  location             InventoryLocation @relation("to_location", fields: [inventoryLocationId], references: [id], onDelete: Cascade)
  fromLocationId       String? // for transfers
  fromLocation         InventoryLocation? @relation("from_location", fields: [fromLocationId], references: [id], onDelete: SetNull)
  storeId              String?
  store                Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  purchaseOrderId      String? // if from PO receipt
  purchaseOrder        PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  createdAt            DateTime @default(now())

  @@index([organizationId])
  @@index([productId])
  @@index([inventoryLocationId])
  @@index([purchaseOrderId])
}

// Suppliers
model Supplier {
  id             String   @id @default(cuid())
  name           String
  code           String
  email          String?
  phone          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  products       Supplier_Product[]
  orders         PurchaseOrder[]

  @@unique([organizationId, code])
  @@index([organizationId])
}

// Supplier <-> Product relationship
model Supplier_Product {
  id          String   @id @default(cuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  isPreferred Boolean  @default(false)
  leadDays    Int      @default(7)
  createdAt   DateTime @default(now())

  @@unique([supplierId, productId])
  @@index([supplierId])
  @@index([productId])
}

// Purchase Orders
model PurchaseOrder {
  id             String   @id @default(cuid())
  orderNumber    String
  status         String   @default("draft") // draft, sent, received, cancelled
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  totalAmount    Decimal  @db.Decimal(12, 2)
  sentAt         DateTime?
  receivedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lineItems      PurchaseOrderLineItem[]
  movements      StockMovement[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@index([supplierId])
  @@index([status])
}

// PO Line Items
model PurchaseOrderLineItem {
  id                String   @id @default(cuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product @relation(fields: [productId], references: [id])
  quantity          Int
  unitPrice         Decimal  @db.Decimal(10, 2)
  lineTotal         Decimal  @db.Decimal(12, 2)
  createdAt         DateTime @default(now())

  @@index([purchaseOrderId])
  @@index([productId])
}

// Low-Stock Alerts
model Alert {
  id             String   @id @default(cuid())
  type           String   @default("low_stock") // low_stock, out_of_stock, high_stock, dead_stock
  severity       String   @default("warning") // info, warning, critical
  status         String   @default("open") // open, acknowledged, resolved
  productId      String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  message        String
  data           String? @db.Text // JSON data
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([severity])
}

// Automation Rules
model Automation {
  id             String   @id @default(cuid())
  name           String
  description    String?
  trigger        String   // event name
  condition      String @db.Text // JSON condition
  action         String @db.Text // JSON action
  enabled        Boolean  @default(true)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// Audit Logs
model AuditLog {
  id             String   @id @default(cuid())
  action         String
  entity         String
  entityId       String
  changes        String? @db.Text // JSON
  userId         String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([entity])
  @@index([entityId])
}
