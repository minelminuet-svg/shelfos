{
  "name": "shelfos",
  "version": "0.0.1",
  "description": "ShelfOS - Retail Operations Automation Platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm -r --filter=@shelfos/api --filter=@shelfos/web --parallel run dev",
    "dev:api": "pnpm -C apps/api dev",
    "dev:web": "pnpm -C apps/web dev",
    "build": "pnpm -r --if-present run build",
    "test": "pnpm -r --if-present run test",
    "db:generate": "pnpm exec prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "pnpm exec prisma migrate dev --schema=prisma/schema.prisma",
    "db:migrate:deploy": "pnpm exec prisma migrate deploy --schema=prisma/schema.prisma",
    "db:seed": "pnpm exec ts-node prisma/seed.ts",
    "db:studio": "pnpm exec prisma studio --schema=prisma/schema.prisma"
  },
  "devDependencies": {
    "@prisma/client": "5.7.1",
    "@types/node": "^20.0.0",
    "prisma": "5.7.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
